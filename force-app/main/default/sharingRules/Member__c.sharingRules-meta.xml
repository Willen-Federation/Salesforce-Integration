<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <!-- 管理者グループは全会員レコードを参照・編集可能 -->
    <sharingCriteriaRules>
        <fullName>MemberAdmin_AllMembers</fullName>
        <accessLevel>Edit</accessLevel>
        <label>管理者グループ：全会員アクセス</label>
        <sharedTo>
            <group>MemberPortalAdmins</group>
        </sharedTo>
        <sharingCriteria>
            <criteriaItems>
                <field>MemberStatus__c</field>
                <operation>equals</operation>
                <value>申請中,正会員,準会員,休会,退会,賛助会員</value>
            </criteriaItems>
        </sharingCriteria>
    </sharingCriteriaRules>
    <!-- 自組織会員は同一OrgUnit内の会員を参照のみ可能 -->
    <sharingOwnerRules>
        <fullName>OrgUnitMember_ReadOwnUnit</fullName>
        <accessLevel>Read</accessLevel>
        <label>同一組織単位会員：参照のみ</label>
        <sharedTo>
            <roleAndSubordinates>CEO</roleAndSubordinates>
        </sharedTo>
        <sharedFrom>
            <roleAndSubordinates>CEO</roleAndSubordinates>
        </sharedFrom>
    </sharingOwnerRules>
</SharingRules>
