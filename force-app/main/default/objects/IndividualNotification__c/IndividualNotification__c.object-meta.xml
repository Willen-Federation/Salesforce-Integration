<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>個別通知</label>
    <pluralLabel>個別通知</pluralLabel>
    <nameField>
        <label>通知番号</label>
        <type>AutoNumber</type>
        <displayFormat>NOTIF-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>false</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Subject__c</fullName>
        <label>件名</label>
        <type>Text</type>
        <length>255</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>BodyTemplate__c</fullName>
        <label>本文テンプレート（PlaceFolder使用可）</label>
        <type>LongTextArea</type>
        <length>131072</length>
        <visibleLines>10</visibleLines>
        <required>true</required>
    </fields>
    <fields>
        <fullName>DeliveryChannels__c</fullName>
        <label>送付チャンネル</label>
        <type>MultiselectPicklist</type>
        <visibleLines>4</visibleLines>
        <required>true</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>個人登録メール</fullName><label>個人登録メール</label><default>false</default></value>
                <value><fullName>Willenメール</fullName><label>Willenメール</label><default>false</default></value>
                <value><fullName>Slack</fullName><label>Slack</label><default>false</default></value>
                <value><fullName>ポータル通知</fullName><label>ポータル通知</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RecipientType__c</fullName>
        <label>宛先種別</label>
        <type>Picklist</type>
        <required>true</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>特定会員</fullName><label>特定会員</label><default>true</default></value>
                <value><fullName>組織単位</fullName><label>組織単位</label><default>false</default></value>
                <value><fullName>会員種別</fullName><label>会員種別</label><default>false</default></value>
                <value><fullName>全会員</fullName><label>全会員</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RecipientMember__c</fullName>
        <label>宛先会員</label>
        <type>Lookup</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>受信通知</relationshipLabel>
        <relationshipName>IndividualNotifications</relationshipName>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RecipientOrgUnit__c</fullName>
        <label>宛先組織単位</label>
        <type>Lookup</type>
        <referenceTo>OrgUnit__c</referenceTo>
        <relationshipLabel>組織通知</relationshipLabel>
        <relationshipName>OrgUnitNotifications</relationshipName>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RecipientMemberType__c</fullName>
        <label>宛先会員種別</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>個人会員</fullName><label>個人会員</label><default>false</default></value>
                <value><fullName>法人会員</fullName><label>法人会員</label><default>false</default></value>
                <value><fullName>学生会員</fullName><label>学生会員</label><default>false</default></value>
                <value><fullName>賛助会員</fullName><label>賛助会員</label><default>false</default></value>
                <value><fullName>名誉会員</fullName><label>名誉会員</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RelatedObjectType__c</fullName>
        <label>関連オブジェクト種別</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Member__c</fullName><label>会員</label><default>false</default></value>
                <value><fullName>Payment__c</fullName><label>支払い</label><default>false</default></value>
                <value><fullName>Donation__c</fullName><label>寄付</label><default>false</default></value>
                <value><fullName>Activity__c</fullName><label>活動</label><default>false</default></value>
                <value><fullName>PersonnelChange__c</fullName><label>人事異動</label><default>false</default></value>
                <value><fullName>SupportInquiry__c</fullName><label>問い合わせ</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RelatedRecordId__c</fullName>
        <label>関連レコードID</label>
        <type>Text</type>
        <length>18</length>
        <required>false</required>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>ScheduledSendTime__c</fullName>
        <label>送信予定日時</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>NotificationStatus__c</fullName>
        <label>送信ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>下書き</fullName><label>下書き</label><default>true</default></value>
                <value><fullName>送信予約</fullName><label>送信予約</label><default>false</default></value>
                <value><fullName>送信済み</fullName><label>送信済み</label><default>false</default></value>
                <value><fullName>失敗</fullName><label>失敗</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>SentCount__c</fullName>
        <label>送信成功数</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>0</scale>
        <defaultValue>0</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>FailedCount__c</fullName>
        <label>送信失敗数</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>0</scale>
        <defaultValue>0</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>WillenEmailDomain__c</fullName>
        <label>Willenメールドメイン</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
        <defaultValue>@willen.jp</defaultValue>
    </fields>
    <fields>
        <fullName>SentAt__c</fullName>
        <label>送信完了日時</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
</CustomObject>
