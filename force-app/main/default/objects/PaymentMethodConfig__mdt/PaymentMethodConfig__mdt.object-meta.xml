<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>決済手段設定</label>
    <pluralLabel>決済手段設定</pluralLabel>
    <visibility>Public</visibility>
    <fields>
        <fullName>ProviderName__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>決済プロバイダー</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>MethodKey__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>手段キー</label>
        <type>Text</type>
        <length>50</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>DisplayName__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>表示名</label>
        <type>Text</type>
        <length>100</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>FeeType__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>手数料種別</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>none</fullName><label>なし</label><default>true</default></value>
                <value><fullName>percent</fullName><label>料率（%）</label><default>false</default></value>
                <value><fullName>fixed</fullName><label>固定額（円）</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>FeeValue__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>手数料値</label>
        <type>Number</type>
        <precision>10</precision>
        <scale>2</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>IsEnabled__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>有効</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RequiresGateway__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>ゲートウェイ処理が必要</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SortOrder__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>表示順</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
</CustomObject>
