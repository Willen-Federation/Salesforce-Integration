<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>正会員</label>
    <pluralLabel>正会員</pluralLabel>
    <nameField>
        <label>会員番号</label>
        <type>AutoNumber</type>
        <displayFormat>MB-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>Private</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>LastName__c</fullName>
        <label>姓</label>
        <type>Text</type>
        <length>50</length>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>FirstName__c</fullName>
        <label>名</label>
        <type>Text</type>
        <length>50</length>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Email__c</fullName>
        <label>メールアドレス</label>
        <type>Email</type>
        <required>true</required>
        <unique>true</unique>
        <externalId>true</externalId>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>MemberStatus__c</fullName>
        <label>会員ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>申請中</fullName><label>申請中</label><default>true</default></value>
                <value><fullName>正会員</fullName><label>正会員</label><default>false</default></value>
                <value><fullName>準会員</fullName><label>準会員</label><default>false</default></value>
                <value><fullName>休会</fullName><label>休会</label><default>false</default></value>
                <value><fullName>退会</fullName><label>退会</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>MemberType__c</fullName>
        <label>会員種別</label>
        <type>Picklist</type>
        <required>true</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>個人会員</fullName><label>個人会員</label><default>true</default></value>
                <value><fullName>法人会員</fullName><label>法人会員</label><default>false</default></value>
                <value><fullName>学生会員</fullName><label>学生会員</label><default>false</default></value>
                <value><fullName>名誉会員</fullName><label>名誉会員</label><default>false</default></value>
                <value><fullName>賛助会員</fullName><label>賛助会員</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>JoinDate__c</fullName>
        <label>入会日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Organization__c</fullName>
        <label>所属組織名</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Department__c</fullName>
        <label>部署</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Position__c</fullName>
        <label>役職</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Phone__c</fullName>
        <label>電話番号</label>
        <type>Phone</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>AnnualFee__c</fullName>
        <label>年会費額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OktaUserId__c</fullName>
        <label>OktaユーザーID</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
        <unique>true</unique>
        <externalId>true</externalId>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>OrgUnit__c</fullName>
        <label>所属組織単位</label>
        <type>Lookup</type>
        <referenceTo>OrgUnit__c</referenceTo>
        <relationshipLabel>所属会員</relationshipLabel>
        <relationshipName>Members</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>SlackUserId__c</fullName>
        <label>SlackユーザーID</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SupportingMemberInfo__c</fullName>
        <label>賛助会員情報</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>5</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SupportingAmount__c</fullName>
        <label>賛助金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Notes__c</fullName>
        <label>備考</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>5</visibleLines>
        <required>false</required>
    </fields>
    <!-- ポータルアクセス管理 -->
    <fields>
        <fullName>PortalAccessToken__c</fullName>
        <label>ポータルアクセストークン</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
        <unique>true</unique>
        <externalId>true</externalId>
    </fields>
    <fields>
        <fullName>PortalTokenExpiry__c</fullName>
        <label>トークン有効期限</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>IsPortalEnabled__c</fullName>
        <label>ポータルアクセス有効</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>
    <searchLayouts>
        <searchResultsAdditionalFields>Email__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>MemberStatus__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>MemberType__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Organization__c</searchResultsAdditionalFields>
    </searchLayouts>
</CustomObject>
