<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>寄付金</label>
    <pluralLabel>寄付金</pluralLabel>
    <nameField>
        <label>寄付番号</label>
        <type>AutoNumber</type>
        <displayFormat>DON-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員</label>
        <type>Lookup</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>寄付履歴</relationshipLabel>
        <relationshipName>Donations</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>DonorName__c</fullName>
        <label>寄付者名（匿名可）</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>DonorEmail__c</fullName>
        <label>寄付者メールアドレス</label>
        <type>Email</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Amount__c</fullName>
        <label>寄付金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Purpose__c</fullName>
        <label>寄付目的・用途</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>一般活動費</fullName><label>一般活動費</label><default>true</default></value>
                <value><fullName>研究助成</fullName><label>研究助成</label><default>false</default></value>
                <value><fullName>教育支援</fullName><label>教育支援</label><default>false</default></value>
                <value><fullName>施設整備</fullName><label>施設整備</label><default>false</default></value>
                <value><fullName>その他指定寄付</fullName><label>その他指定寄付</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DonationStatus__c</fullName>
        <label>ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>受付済み</fullName><label>受付済み</label><default>true</default></value>
                <value><fullName>入金確認済み</fullName><label>入金確認済み</label><default>false</default></value>
                <value><fullName>領収書発行済み</fullName><label>領収書発行済み</label><default>false</default></value>
                <value><fullName>キャンセル</fullName><label>キャンセル</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DonationDate__c</fullName>
        <label>寄付日</label>
        <type>Date</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>IsAnonymous__c</fullName>
        <label>匿名</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>PaymentMethod__c</fullName>
        <label>支払方法</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>クレジットカード</fullName><label>クレジットカード</label><default>false</default></value>
                <value><fullName>銀行振込</fullName><label>銀行振込</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>TaxDeductionCertRequired__c</fullName>
        <label>税控除証明書要否</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>ReceiptNumber__c</fullName>
        <label>寄付領収書番号</label>
        <type>AutoNumber</type>
        <displayFormat>DRCP-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </fields>
    <fields>
        <fullName>Message__c</fullName>
        <label>メッセージ</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>4</visibleLines>
        <required>false</required>
    </fields>
</CustomObject>
