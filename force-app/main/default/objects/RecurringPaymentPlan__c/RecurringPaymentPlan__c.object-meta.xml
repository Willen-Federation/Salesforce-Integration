<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>定期支払いプラン</label>
    <pluralLabel>定期支払いプラン</pluralLabel>
    <nameField>
        <label>プラン番号</label>
        <type>AutoNumber</type>
        <displayFormat>RPP-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員</label>
        <type>MasterDetail</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>定期支払いプラン</relationshipLabel>
        <relationshipName>RecurringPaymentPlans</relationshipName>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PlanName__c</fullName>
        <label>プラン名</label>
        <type>Text</type>
        <length>100</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>PaymentType__c</fullName>
        <label>支払種別</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>年会費</fullName><label>年会費</label><default>true</default></value>
                <value><fullName>個別利用料</fullName><label>個別利用料</label><default>false</default></value>
                <value><fullName>イベント参加費</fullName><label>イベント参加費</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>BaseAmount__c</fullName>
        <label>基本金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Frequency__c</fullName>
        <label>頻度</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>月次</fullName><label>月次（毎月）</label><default>false</default></value>
                <value><fullName>四半期</fullName><label>四半期（3ヶ月ごと）</label><default>false</default></value>
                <value><fullName>半期</fullName><label>半期（6ヶ月ごと）</label><default>false</default></value>
                <value><fullName>年次</fullName><label>年次（毎年）</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>StartDate__c</fullName>
        <label>開始日</label>
        <type>Date</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>EndDate__c</fullName>
        <label>終了日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>NextDueDate__c</fullName>
        <label>次回支払期限</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>DaysBeforeDue__c</fullName>
        <label>支払期限の何日前に請求を作成するか</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
        <required>false</required>
        <defaultValue>7</defaultValue>
    </fields>
    <fields>
        <fullName>AllowedPaymentMethods__c</fullName>
        <label>利用可能決済手段</label>
        <type>LongTextArea</type>
        <length>500</length>
        <visibleLines>3</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>IsActive__c</fullName>
        <label>有効</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <label>摘要テンプレート</label>
        <type>TextArea</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>LastGeneratedDate__c</fullName>
        <label>最終請求生成日</label>
        <type>Date</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>TotalGenerated__c</fullName>
        <label>累計生成回数</label>
        <type>Number</type>
        <precision>6</precision>
        <scale>0</scale>
        <required>false</required>
        <defaultValue>0</defaultValue>
    </fields>
</CustomObject>
