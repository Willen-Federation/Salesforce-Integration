<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>サポート・お問い合わせ</label>
    <pluralLabel>サポート・お問い合わせ</pluralLabel>
    <nameField>
        <label>問い合わせ番号</label>
        <type>AutoNumber</type>
        <displayFormat>INQ-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>問い合わせ会員</label>
        <type>Lookup</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>問い合わせ履歴</relationshipLabel>
        <relationshipName>SupportInquiries</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ContactEmail__c</fullName>
        <label>連絡先メールアドレス</label>
        <type>Email</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ContactName__c</fullName>
        <label>お名前</label>
        <type>Text</type>
        <length>100</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>Category__c</fullName>
        <label>問い合わせカテゴリ</label>
        <type>Picklist</type>
        <required>true</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>会員登録・手続き</fullName><label>会員登録・手続き</label><default>false</default></value>
                <value><fullName>支払い・請求</fullName><label>支払い・請求</label><default>false</default></value>
                <value><fullName>システム・ログイン</fullName><label>システム・ログイン</label><default>false</default></value>
                <value><fullName>活動・イベント</fullName><label>活動・イベント</label><default>false</default></value>
                <value><fullName>個人情報変更</fullName><label>個人情報変更</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Subject__c</fullName>
        <label>件名</label>
        <type>Text</type>
        <length>255</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>Body__c</fullName>
        <label>問い合わせ内容</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>8</visibleLines>
        <required>true</required>
    </fields>
    <fields>
        <fullName>InquiryStatus__c</fullName>
        <label>対応ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>受付済み</fullName><label>受付済み</label><default>true</default></value>
                <value><fullName>対応中</fullName><label>対応中</label><default>false</default></value>
                <value><fullName>回答済み</fullName><label>回答済み</label><default>false</default></value>
                <value><fullName>完了</fullName><label>完了</label><default>false</default></value>
                <value><fullName>保留</fullName><label>保留</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Priority__c</fullName>
        <label>優先度</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>高</fullName><label>高</label><default>false</default></value>
                <value><fullName>中</fullName><label>中</label><default>true</default></value>
                <value><fullName>低</fullName><label>低</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>AssignedTo__c</fullName>
        <label>担当者</label>
        <type>Lookup</type>
        <referenceTo>User</referenceTo>
        <relationshipLabel>担当問い合わせ</relationshipLabel>
        <relationshipName>AssignedInquiries</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Response__c</fullName>
        <label>回答内容</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>8</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>ResponseDate__c</fullName>
        <label>回答日</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>SatisfactionRating__c</fullName>
        <label>満足度</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>5 - 大変満足</fullName><label>5 - 大変満足</label><default>false</default></value>
                <value><fullName>4 - 満足</fullName><label>4 - 満足</label><default>false</default></value>
                <value><fullName>3 - 普通</fullName><label>3 - 普通</label><default>false</default></value>
                <value><fullName>2 - 不満</fullName><label>2 - 不満</label><default>false</default></value>
                <value><fullName>1 - 大変不満</fullName><label>1 - 大変不満</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>NotifySlack__c</fullName>
        <label>Slack通知</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>
    <fields>
        <fullName>NotifyEmail__c</fullName>
        <label>メール通知</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>
    <fields>
        <fullName>IsAuthenticatedMember__c</fullName>
        <label>Okta認証済み会員</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>SLADeadline__c</fullName>
        <label>SLA期限</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>FirstResponseDate__c</fullName>
        <label>初回回答日時</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>IsSLAMet__c</fullName>
        <label>SLA達成</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>EscalatedTo__c</fullName>
        <label>エスカレーション先</label>
        <type>Lookup</type>
        <referenceTo>User</referenceTo>
        <relationshipLabel>エスカレーション問い合わせ</relationshipLabel>
        <relationshipName>EscalatedInquiries</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>EscalationDate__c</fullName>
        <label>エスカレーション日時</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>EscalationReason__c</fullName>
        <label>エスカレーション理由</label>
        <type>TextArea</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>InternalNote__c</fullName>
        <label>内部メモ（非公開）</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>5</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Tags__c</fullName>
        <label>タグ</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RelatedPayment__c</fullName>
        <label>関連支払い</label>
        <type>Lookup</type>
        <referenceTo>Payment__c</referenceTo>
        <relationshipLabel>問い合わせ</relationshipLabel>
        <relationshipName>SupportInquiries</relationshipName>
        <required>false</required>
    </fields>
</CustomObject>
