<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>活動記録</label>
    <pluralLabel>活動記録</pluralLabel>
    <nameField>
        <label>活動番号</label>
        <type>AutoNumber</type>
        <displayFormat>ACT-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員（主催者）</label>
        <type>Lookup</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>活動・イベント</relationshipLabel>
        <relationshipName>Activities</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>IsEvent__c</fullName>
        <label>イベント予定</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>IsPublic__c</fullName>
        <label>外部公開</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>EventStartDatetime__c</fullName>
        <label>開始日時</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>EventEndDatetime__c</fullName>
        <label>終了日時</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RegistrationDeadline__c</fullName>
        <label>参加申込締切日</label>
        <type>Date</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>MaxParticipants__c</fullName>
        <label>定員</label>
        <type>Number</type>
        <precision>6</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>CurrentParticipants__c</fullName>
        <label>参加申込人数</label>
        <type>Number</type>
        <precision>6</precision>
        <scale>0</scale>
        <defaultValue>0</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>RegistrationFee__c</fullName>
        <label>参加費</label>
        <type>Currency</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OnlineUrl__c</fullName>
        <label>オンラインURL</label>
        <type>Url</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>ActivityTitle__c</fullName>
        <label>活動タイトル</label>
        <type>Text</type>
        <length>255</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ActivityType__c</fullName>
        <label>活動種別</label>
        <type>Picklist</type>
        <required>true</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>会議出席</fullName><label>会議出席</label><default>false</default></value>
                <value><fullName>セミナー参加</fullName><label>セミナー参加</label><default>false</default></value>
                <value><fullName>委員会活動</fullName><label>委員会活動</label><default>false</default></value>
                <value><fullName>ボランティア</fullName><label>ボランティア</label><default>false</default></value>
                <value><fullName>研究発表</fullName><label>研究発表</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>ActivityDate__c</fullName>
        <label>活動日</label>
        <type>Date</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ActivityStatus__c</fullName>
        <label>ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>登録済み</fullName><label>登録済み</label><default>true</default></value>
                <value><fullName>承認済み</fullName><label>承認済み</label><default>false</default></value>
                <value><fullName>完了</fullName><label>完了</label><default>false</default></value>
                <value><fullName>キャンセル</fullName><label>キャンセル</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Location__c</fullName>
        <label>場所</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Hours__c</fullName>
        <label>活動時間（時間）</label>
        <type>Number</type>
        <precision>4</precision>
        <scale>1</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <label>活動内容詳細</label>
        <type>LongTextArea</type>
        <length>32768</length>
        <visibleLines>5</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Points__c</fullName>
        <label>活動ポイント</label>
        <type>Number</type>
        <precision>6</precision>
        <scale>0</scale>
        <defaultValue>0</defaultValue>
        <required>false</required>
    </fields>
</CustomObject>
