<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>ポータル設定</label>
    <visibility>Public</visibility>
    <customSettingsType>Hierarchy</customSettingsType>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>OrganizationName__c</fullName>
        <label>組織名</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>FromEmailAddress__c</fullName>
        <label>送信元メールアドレス</label>
        <type>Email</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SupportSlackChannelId__c</fullName>
        <label>サポートSlackチャンネルID</label>
        <type>Text</type>
        <length>20</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SlackBotToken__c</fullName>
        <label>Slackボットトークン</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OktaDomain__c</fullName>
        <label>OktaドメインURL</label>
        <type>Url</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OktaApiToken__c</fullName>
        <label>Okta APIトークン</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>PortalBaseUrl__c</fullName>
        <label>ポータルベースURL</label>
        <type>Url</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>AnnualFeeIndividual__c</fullName>
        <label>個人会員年会費</label>
        <type>Currency</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>AnnualFeeCorporate__c</fullName>
        <label>法人会員年会費</label>
        <type>Currency</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>AnnualFeeStudent__c</fullName>
        <label>学生会員年会費</label>
        <type>Currency</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>AnnualFeeSupporting__c</fullName>
        <label>賛助会員年会費</label>
        <type>Currency</type>
        <precision>10</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>EnableDonation__c</fullName>
        <label>寄付機能を有効化</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
        <required>false</required>
    </fields>
    <fields>
        <fullName>EnableSlackNotification__c</fullName>
        <label>Slack通知を有効化</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
        <required>false</required>
    </fields>
    <!-- Pay.jp Settings -->
    <fields>
        <fullName>PayjpPublicKey__c</fullName>
        <label>Pay.jp 公開キー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>PayjpSecretKey__c</fullName>
        <label>Pay.jp シークレットキー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>PayjpMode__c</fullName>
        <label>Pay.jp 環境</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>本番</fullName><label>本番</label><default>false</default></value>
                <value><fullName>テスト</fullName><label>テスト</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DirectDebitFormUrl__c</fullName>
        <label>口座振替申込書URL</label>
        <type>Url</type>
        <required>false</required>
    </fields>
    <!-- Omise Settings -->
    <fields>
        <fullName>OmisePublicKey__c</fullName>
        <label>Omise 公開キー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OmiseSecretKey__c</fullName>
        <label>Omise シークレットキー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>OmiseMode__c</fullName>
        <label>Omise 環境</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>本番</fullName><label>本番</label><default>false</default></value>
                <value><fullName>テスト</fullName><label>テスト</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- Stripe Settings -->
    <fields>
        <fullName>StripePublicKey__c</fullName>
        <label>Stripe 公開キー</label>
        <type>Text</type>
        <length>120</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>StripeSecretKey__c</fullName>
        <label>Stripe シークレットキー</label>
        <type>Text</type>
        <length>120</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>StripeMode__c</fullName>
        <label>Stripe 環境</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>本番</fullName><label>本番</label><default>false</default></value>
                <value><fullName>テスト</fullName><label>テスト</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- GMO Aozora Net Bank Settings -->
    <fields>
        <fullName>DefaultPaymentProvider__c</fullName>
        <label>デフォルト決済プロバイダー</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>GMOあおぞら</fullName><label>GMOあおぞら</label><default>true</default></value>
                <value><fullName>Pay.jp</fullName><label>Pay.jp</label><default>false</default></value>
                <value><fullName>Omise</fullName><label>Omise</label><default>false</default></value>
                <value><fullName>Stripe</fullName><label>Stripe</label><default>false</default></value>
                <value><fullName>Fincode</fullName><label>Fincode</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>GmoAozoraMode__c</fullName>
        <label>GMOあおぞら 環境</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>テスト</fullName><label>テスト</label><default>true</default></value>
                <value><fullName>本番</fullName><label>本番</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>GmoAozoraClientId__c</fullName>
        <label>GMOあおぞら クライアントID</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>GmoAozoraClientSecret__c</fullName>
        <label>GMOあおぞら クライアントシークレット</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>GmoAozoraWebhookSecret__c</fullName>
        <label>GMOあおぞら Webhookシークレット</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
    </fields>
    <!-- Fincode Settings -->
    <fields>
        <fullName>FincodeShopId__c</fullName>
        <label>Fincode ショップID</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>FincodePublicKey__c</fullName>
        <label>Fincode 公開キー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>FincodeSecretKey__c</fullName>
        <label>Fincode シークレットキー</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>FincodeMode__c</fullName>
        <label>Fincode 環境</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>本番</fullName><label>本番</label><default>false</default></value>
                <value><fullName>テスト</fullName><label>テスト</label><default>true</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
</CustomObject>
