<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>支払い</label>
    <pluralLabel>支払い</pluralLabel>
    <nameField>
        <label>支払い番号</label>
        <type>AutoNumber</type>
        <displayFormat>PAY-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員</label>
        <type>MasterDetail</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>支払い履歴</relationshipLabel>
        <relationshipName>Payments</relationshipName>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentType__c</fullName>
        <label>支払種別</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>年会費</fullName><label>年会費</label><default>true</default></value>
                <value><fullName>個別利用料</fullName><label>個別利用料</label><default>false</default></value>
                <value><fullName>イベント参加費</fullName><label>イベント参加費</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Amount__c</fullName>
        <label>金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentStatus__c</fullName>
        <label>支払いステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>未払い</fullName><label>未払い</label><default>true</default></value>
                <value><fullName>支払済み</fullName><label>支払済み</label><default>false</default></value>
                <value><fullName>キャンセル</fullName><label>キャンセル</label><default>false</default></value>
                <value><fullName>返金済み</fullName><label>返金済み</label><default>false</default></value>
                <value><fullName>延滞</fullName><label>延滞</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DueDate__c</fullName>
        <label>支払期限</label>
        <type>Date</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentDate__c</fullName>
        <label>支払日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentMethod__c</fullName>
        <label>支払方法</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>クレジットカード（Visa/Mastercard）</fullName><label>クレジットカード（Visa/Mastercard）</label><default>false</default></value>
                <value><fullName>銀行振込</fullName><label>銀行振込</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
                <value><fullName>口座振替申込書</fullName><label>口座振替申込書</label><default>false</default></value>
                <value><fullName>請求書払い</fullName><label>請求書払い</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PaymentProvider__c</fullName>
        <label>決済プロバイダー</label>
        <type>Picklist</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Pay.jp</fullName><label>Pay.jp</label><default>false</default></value>
                <value><fullName>Omise</fullName><label>Omise</label><default>false</default></value>
                <value><fullName>Stripe</fullName><label>Stripe</label><default>false</default></value>
                <value><fullName>Fincode</fullName><label>Fincode</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>CardBrand__c</fullName>
        <label>カードブランド</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Visa</fullName><label>Visa</label><default>false</default></value>
                <value><fullName>Mastercard</fullName><label>Mastercard</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DirectDebitApplicationSent__c</fullName>
        <label>口座振替申込書送付済み</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>TransactionId__c</fullName>
        <label>決済トランザクションID</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
        <unique>true</unique>
        <externalId>true</externalId>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>FiscalYear__c</fullName>
        <label>会計年度</label>
        <type>Number</type>
        <precision>4</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <label>摘要</label>
        <type>TextArea</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>ReceiptIssued__c</fullName>
        <label>領収書発行済み</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ReceiptIssuedDate__c</fullName>
        <label>領収書発行日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ReceiptNumber__c</fullName>
