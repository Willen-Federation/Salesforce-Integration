<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>支払い</label>
    <pluralLabel>支払い</pluralLabel>
    <nameField>
        <label>支払い番号</label>
        <type>AutoNumber</type>
        <displayFormat>PAY-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableActivities>true</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員</label>
        <type>MasterDetail</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>支払い履歴</relationshipLabel>
        <relationshipName>Payments</relationshipName>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentType__c</fullName>
        <label>支払種別</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>年会費</fullName><label>年会費</label><default>true</default></value>
                <value><fullName>個別利用料</fullName><label>個別利用料</label><default>false</default></value>
                <value><fullName>イベント参加費</fullName><label>イベント参加費</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Amount__c</fullName>
        <label>金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentStatus__c</fullName>
        <label>支払いステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>未払い</fullName><label>未払い</label><default>true</default></value>
                <value><fullName>支払済み</fullName><label>支払済み</label><default>false</default></value>
                <value><fullName>キャンセル</fullName><label>キャンセル</label><default>false</default></value>
                <value><fullName>返金済み</fullName><label>返金済み</label><default>false</default></value>
                <value><fullName>延滞</fullName><label>延滞</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DueDate__c</fullName>
        <label>支払期限</label>
        <type>Date</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentDate__c</fullName>
        <label>支払日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>PaymentMethod__c</fullName>
        <label>支払方法</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>GMOあおぞら銀行振込</fullName><label>GMOあおぞら銀行振込</label><default>true</default></value>
                <value><fullName>クレジットカード（Visa/Mastercard）</fullName><label>クレジットカード（Visa/Mastercard）</label><default>false</default></value>
                <value><fullName>銀行振込</fullName><label>銀行振込</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
                <value><fullName>口座振替申込書</fullName><label>口座振替申込書</label><default>false</default></value>
                <value><fullName>請求書払い</fullName><label>請求書払い</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>PaymentProvider__c</fullName>
        <label>決済プロバイダー</label>
        <type>Picklist</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>GMOあおぞら</fullName><label>GMOあおぞら</label><default>true</default></value>
                <value><fullName>Pay.jp</fullName><label>Pay.jp</label><default>false</default></value>
                <value><fullName>Omise</fullName><label>Omise</label><default>false</default></value>
                <value><fullName>Stripe</fullName><label>Stripe</label><default>false</default></value>
                <value><fullName>Fincode</fullName><label>Fincode</label><default>false</default></value>
                <value><fullName>口座振替</fullName><label>口座振替</label><default>false</default></value>
                <value><fullName>その他</fullName><label>その他</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>CardBrand__c</fullName>
        <label>カードブランド</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Visa</fullName><label>Visa</label><default>false</default></value>
                <value><fullName>Mastercard</fullName><label>Mastercard</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DirectDebitApplicationSent__c</fullName>
        <label>口座振替申込書送付済み</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>TransactionId__c</fullName>
        <label>決済トランザクションID</label>
        <type>Text</type>
        <length>255</length>
        <required>false</required>
        <unique>true</unique>
        <externalId>true</externalId>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>FiscalYear__c</fullName>
        <label>会計年度</label>
        <type>Number</type>
        <precision>4</precision>
        <scale>0</scale>
        <required>false</required>
    </fields>
    <fields>
        <fullName>Description__c</fullName>
        <label>摘要</label>
        <type>TextArea</type>
        <required>false</required>
    </fields>
    <!-- GMOあおぞらネット銀行 バーチャル口座情報 -->
    <fields>
        <fullName>VirtualAccountNumber__c</fullName>
        <label>バーチャル口座番号</label>
        <type>Text</type>
        <length>20</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>VirtualAccountBranchCode__c</fullName>
        <label>バーチャル口座 支店コード</label>
        <type>Text</type>
        <length>10</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>VirtualAccountBranchName__c</fullName>
        <label>バーチャル口座 支店名</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>VirtualAccountName__c</fullName>
        <label>バーチャル口座 口座名義</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>VirtualAccountExpiresAt__c</fullName>
        <label>バーチャル口座 振込期限</label>
        <type>Date</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>DepositConfirmedAt__c</fullName>
        <label>入金確認日時</label>
        <type>DateTime</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>DepositAmount__c</fullName>
        <label>入金確認金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>GmoTransferId__c</fullName>
        <label>GMOあおぞら 振込ID</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <!-- GMOあおぞら 自動振込情報 -->
    <fields>
        <fullName>AutoTransferApplyNo__c</fullName>
        <label>自動振込 申請番号</label>
        <type>Text</type>
        <length>16</length>
        <required>false</required>
        <unique>false</unique>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>AutoTransferStatus__c</fullName>
        <label>自動振込ステータス</label>
        <type>Picklist</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>未実行</fullName><label>未実行</label><default>false</default></value>
                <value><fullName>振込依頼済</fullName><label>振込依頼済</label><default>false</default></value>
                <value><fullName>振込依頼失敗</fullName><label>振込依頼失敗</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>

    <fields>
        <fullName>ReceiptIssued__c</fullName>
        <label>領収書発行済み</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ReceiptIssuedDate__c</fullName>
        <label>領収書発行日</label>
        <type>Date</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ReceiptNumber__c</fullName>
        <label>領収書番号</label>
        <type>AutoNumber</type>
        <displayFormat>RCP-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>BaseAmount__c</fullName>
        <label>基本金額</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>PlatformFee__c</fullName>
        <label>プラットフォーム利用手数料</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>AllowedPaymentMethods__c</fullName>
        <label>利用可能決済手段</label>
        <type>LongTextArea</type>
        <length>1000</length>
        <visibleLines>3</visibleLines>
        <required>false</required>
    </fields>
    <fields>
        <fullName>SelectedMethodKey__c</fullName>
        <label>選択済み決済手段キー</label>
        <type>Text</type>
        <length>50</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>PaymentMethodFee__c</fullName>
        <label>決済手段手数料</label>
        <type>Currency</type>
        <precision>12</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
    </fields>
    <fields>
        <fullName>FeeBreakdown__c</fullName>
        <label>手数料内訳（JSON）</label>
        <type>LongTextArea</type>
        <length>4000</length>
        <visibleLines>3</visibleLines>
        <required>false</required>
    </fields>
    <!-- 審査ワークフロー -->
    <fields>
        <fullName>ReviewRequired__c</fullName>
        <label>審査が必要</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ReviewStatus__c</fullName>
        <label>審査ステータス</label>
        <type>Picklist</type>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>不要</fullName><label>不要</label><default>true</default></value>
                <value><fullName>審査待ち</fullName><label>審査待ち</label><default>false</default></value>
                <value><fullName>承認済</fullName><label>承認済</label><default>false</default></value>
                <value><fullName>却下</fullName><label>却下</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>ReviewNotes__c</fullName>
        <label>審査コメント</label>
        <type>TextArea</type>
        <required>false</required>
        <trackHistory>false</trackHistory>
    </fields>
    <!-- 定期支払いリンク -->
    <fields>
        <fullName>RecurringPlan__c</fullName>
        <label>定期支払いプラン</label>
        <type>Lookup</type>
        <referenceTo>RecurringPaymentPlan__c</referenceTo>
        <relationshipLabel>生成済み支払い</relationshipLabel>
        <relationshipName>GeneratedPayments</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
    </fields>
</CustomObject>
