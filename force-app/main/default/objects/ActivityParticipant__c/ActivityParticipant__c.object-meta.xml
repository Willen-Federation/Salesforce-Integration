<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>活動参加申込</label>
    <pluralLabel>活動参加申込</pluralLabel>
    <nameField>
        <label>参加申込番号</label>
        <type>AutoNumber</type>
        <displayFormat>PART-{0000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ControlledByParent</sharingModel>
    <enableActivities>false</enableActivities>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <fields>
        <fullName>Activity__c</fullName>
        <label>活動・イベント</label>
        <type>MasterDetail</type>
        <referenceTo>Activity__c</referenceTo>
        <relationshipLabel>参加申込</relationshipLabel>
        <relationshipName>Participants</relationshipName>
        <required>true</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>Member__c</fullName>
        <label>会員</label>
        <type>Lookup</type>
        <referenceTo>Member__c</referenceTo>
        <relationshipLabel>参加申込</relationshipLabel>
        <relationshipName>ActivityParticipants</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
    </fields>
    <fields>
        <fullName>ParticipantName__c</fullName>
        <label>参加者氏名</label>
        <type>Text</type>
        <length>100</length>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ParticipantEmail__c</fullName>
        <label>参加者メールアドレス</label>
        <type>Email</type>
        <required>true</required>
    </fields>
    <fields>
        <fullName>ParticipantOrganization__c</fullName>
        <label>所属組織</label>
        <type>Text</type>
        <length>100</length>
        <required>false</required>
    </fields>
    <fields>
        <fullName>ParticipationStatus__c</fullName>
        <label>参加ステータス</label>
        <type>Picklist</type>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>申込済み</fullName><label>申込済み</label><default>true</default></value>
                <value><fullName>確定</fullName><label>確定</label><default>false</default></value>
                <value><fullName>キャンセル</fullName><label>キャンセル</label><default>false</default></value>
                <value><fullName>出席</fullName><label>出席</label><default>false</default></value>
                <value><fullName>欠席</fullName><label>欠席</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>IsExternalParticipant__c</fullName>
        <label>外部参加者</label>
        <type>Checkbox</type>
        <defaultValue>false</defaultValue>
    </fields>
    <fields>
        <fullName>RegistrationDate__c</fullName>
        <label>申込日時</label>
        <type>DateTime</type>
        <required>false</required>
    </fields>
    <fields>
        <fullName>PaymentStatus__c</fullName>
        <label>参加費支払い</label>
        <type>Picklist</type>
        <required>false</required>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>不要</fullName><label>不要</label><default>true</default></value>
                <value><fullName>未払い</fullName><label>未払い</label><default>false</default></value>
                <value><fullName>支払済み</fullName><label>支払済み</label><default>false</default></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Remarks__c</fullName>
        <label>備考・メッセージ</label>
        <type>LongTextArea</type>
        <length>2000</length>
        <visibleLines>3</visibleLines>
        <required>false</required>
    </fields>
</CustomObject>
